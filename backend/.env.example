# Application
APP_NAME=AutoRec
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Database
DATABASE_URL=sqlite+aiosqlite:///./autorec.db

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# ML Engine
MAX_TRAINING_WORKERS=4
CV_FOLDS=5
TEST_SIZE=0.2
RANDOM_STATE=42

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
