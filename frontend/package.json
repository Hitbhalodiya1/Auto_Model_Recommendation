    "recharts": "^2.12.7",
    "plotly.js": "^2.33.0",
    "react-plotly.js": "^2.6.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "lucide-react": "^0.395.0",
